# ── MySQL ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=nexportal

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── Server ─────────────────────────────────────────────────────
PORT=4000
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# ── Email / SMTP ───────────────────────────────────────────────
# For Gmail: enable 2FA → generate an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=NexPortal <your_email@gmail.com>

# Hour of day (0-23) to send daily notifications (default: 9 = 9 AM)
NOTIFICATION_HOUR=9
